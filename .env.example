# Copy to .env (cp .env.example .env) and fill in.
# The app logs in headless with these credentials on startup (no window).
# In CI/CD, set them as secrets instead of committing a .env file.
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# Optional: lock the WHOLE API behind a shared secret. Set to the SHA-256 hex of
# your secret; clients then send `Authorization: Bearer <secret>` or
# `X-API-Key: <secret>`. Unset = no auth. Only the hash is stored (safe to commit).
# Generate: python3 -c "import hashlib;print(hashlib.sha256(b'YOUR_SECRET').hexdigest())"
# Both local dev and the deployed server read this from .env (the server's
# docker-compose.server.yml references ${API_AUTH_SHA256}; .env is rsync'd by
# deploy.sh and is gitignored, so the real hash never enters the repo).
API_AUTH_SHA256=

# Optional: scrape concurrency. Default 1 = exact legacy behavior (login + all
# scrapes share ONE persistent context, strictly serialized). Set >= 2 to route
# data fetches (/extract, /profile, /company) through a pool of N cookie-seeded
# ephemeral contexts running in parallel. Each pool worker is a full Chromium
# (~150-300MB RAM), so size this to the box (2-3 is sane on a 1GB-shm container).
# ANTI-BOT CAUTION: more concurrent navigations from one IP raises LinkedIn's
# scrutiny — start at 2 and watch the logs for /checkpoint before raising it.
SCRAPE_POOL_SIZE=1

# Optional: seconds a request waits for a free scrape worker before failing
# fast with HTTP 503 + Retry-After (the backpressure that keeps the app from
# degrading under bursts). 0 = wait forever (old behavior — only use if you'd
# rather queue than 503). Only takes effect when SCRAPE_POOL_SIZE >= 2.
SCRAPE_QUEUE_TIMEOUT=0

# Optional: HARD wall-clock cap (seconds) on a single scrape. If the browser op
# hasn't returned by then the caller gets HTTP 504 fast and the worker's Chromium
# is SIGKILL'd + replaced — so a wedged browser can never hang a slot forever or
# leak memory. Default 180 covers a full company scrape; use ~45 for single-page
# only. Applies on both the pool and default single-worker paths.
SCRAPE_DEADLINE_SECONDS=180

# Optional: recycle a scrape worker's Chromium after this many requests to shed
# in-process memory growth (a long-lived Chromium bloats over many heavy
# navigations; this closes+relaunches it on the next acquire). 0 = never recycle.
# Only takes effect when SCRAPE_POOL_SIZE >= 2.
SCRAPE_WORKER_MAX_REQUESTS=40

# --- circuit breaker (#8) --------------------------------------------------
# When the session dies, every fetch lands on /login|/authwall|/checkpoint. After
# CB_THRESHOLD consecutive wall-hits the breaker opens: NEW scrapes fast-fail
# (409 + Retry-After) and a background re-login is kicked, while cached data
# still flows. Auto-resets after CB_COOLDOWN_SECONDS. Set threshold high to
# effectively disable.
CB_THRESHOLD=3
CB_COOLDOWN_SECONDS=60

# --- async jobs + streaming (#12, #6) --------------------------------------
# ?async=1 on /extract /profile /company returns 202 + job_id immediately (so a
# long scrape can't outlive a client timeout); poll GET /jobs/{id}, or subscribe
# GET /jobs/{id}/events (SSE) to wait on one connection. Jobs run on this bounded
# worker pool and reuse the cache/pool/breaker. JOB_MAX_PENDING caps memory.
JOB_WORKERS=2
JOB_MAX_PENDING=128
JOB_TTL_SECONDS=3600

# --- horizontal scaling (#11) ----------------------------------------------
# Per-replica identity surfaced in /health (helps the LB/debugging). With N
# replicas each having its own LINKEDIN account + profile volume behind a
# round-robin LB, capacity scales linearly. See docs/SCALING.md.
INSTANCE_ID=

# --- result cache + single-flight (#1, #2) ---------------------------------
# Repeat hits to the same URL are served from a TTL cache (~0ms, no browser),
# and N concurrent requests for the SAME url share ONE scrape (single-flight:
# fewer parallel hits = better stealth + throughput). Bypass per-request with
# ?force=1. Cleared on /login/reset. Set CACHE_DISABLED=1 to turn it off.
CACHE_DISABLED=
CACHE_MAX_ENTRIES=512
# TTLs (seconds) per endpoint. Profiles/extract ~1h; companies (slow-moving) ~6h.
CACHE_TTL_EXTRACT=3600
CACHE_TTL_EXTRACT_FULL=3600
CACHE_TTL_COMPANY=21600
CACHE_TTL_PROFILE=3600
